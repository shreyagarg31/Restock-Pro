---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { buildMeta } from '@/lib/seo';
import { SITE_NAME, SUPPORT_EMAIL } from '@/lib/constants';

const meta = buildMeta({
  title: 'Privacy Policy',
  description: `Privacy policy for ${SITE_NAME} — how we collect, use, and protect merchant and customer data.`,
  path: '/privacy',
});
---

<BaseLayout {...meta}>
  <section class="px-4 py-16 sm:px-6">
    <div class="prose prose-invert prose-invert-custom mx-auto max-w-3xl prose-headings:font-serif prose-headings:font-normal prose-headings:text-white prose-p:text-text-muted prose-a:text-brand-300">
      <h1 class="page-title">Privacy Policy</h1>
      <p><em>Last updated: March 15, 2026</em></p>
      <p>
        {SITE_NAME} ("we", "us") provides a Shopify application that helps merchants send
        back-in-stock notification emails to customers who subscribe on out-of-stock product pages.
      </p>

      <h2>Information we collect</h2>
      <ul>
        <li><strong>Merchant data:</strong> Shopify store information required to operate the app.</li>
        <li>
          <strong>Subscriber data:</strong> Email addresses and product subscription preferences
          submitted by customers via the Notify Me widget.
        </li>
        <li>
          <strong>Usage data:</strong> Logs related to email delivery, inventory events, and app
          performance.
        </li>
      </ul>

      <h2>How we use information</h2>
      <p>We use collected data to:</p>
      <ul>
        <li>Provide back-in-stock notification services</li>
        <li>Display subscriber lists and analytics to merchants</li>
        <li>Send transactional emails on behalf of merchants</li>
        <li>Improve app reliability and security</li>
      </ul>

      <h2>Data sharing</h2>
      <p>
        We do not sell personal data. We share data only with service providers necessary to
        operate the app (e.g., email delivery) and when required by law.
      </p>

      <h2>Customer rights</h2>
      <p>
        Customers may unsubscribe from restock emails at any time via the link in each email or
        through the merchant's storefront.
      </p>

      <h2>Contact</h2>
      <p>
        Questions about this policy? Email <a href={`mailto:${SUPPORT_EMAIL}`}>{SUPPORT_EMAIL}</a>.
      </p>
    </div>
  </section>
</BaseLayout>
