---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { buildMeta, canonicalUrl } from '@/lib/seo';
import { SITE_NAME, SITE_URL } from '@/lib/constants';

const meta = buildMeta({
  title: 'Blog',
  description:
    'Tips on inventory, back-in-stock marketing, and growing Shopify sales with restock notifications.',
  path: '/blog',
});

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: `${SITE_NAME} Blog`,
  description: meta.description,
  url: canonicalUrl('/blog'),
  publisher: { '@type': 'Organization', name: SITE_NAME, url: SITE_URL },
  blogPost: posts.map((post) => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.pubDate.toISOString(),
    url: canonicalUrl(`/blog/${post.id}`),
  })),
};
---

<BaseLayout {...meta} jsonLd={jsonLd}>
  <section class="relative overflow-hidden border-b hairline px-4 py-20 sm:px-6">
    <div class="pointer-events-none absolute -right-20 top-0 h-64 w-64 rounded-full bg-brand-violet/15 blur-3xl" />
    <div class="relative mx-auto grid max-w-6xl gap-12 lg:grid-cols-2 lg:items-center">
      <div>
        <h1 class="page-title-lg">Thoughts on building useful things.</h1>
        <p class="section-lead mt-4 max-w-lg">
          Ideas on inventory, demand capture, and commerce from the Restock Pro team.
        </p>
      </div>
      <div class="hidden justify-end lg:flex">
        <div class="glass-card glow-brand h-48 w-48 rotate-6 opacity-60" />
        <div class="glass-card -ml-12 h-48 w-48 -rotate-3 opacity-80" />
      </div>
    </div>
  </section>

  <section class="px-4 py-12 sm:px-6">
    <div class="mx-auto max-w-4xl">
      {
        posts.length === 0 ? (
          <p class="body-text text-center">No posts yet. Check back soon.</p>
        ) : (
          <div class="divide-y hairline">
            {posts.map((post) => (
              <article class="group grid gap-4 py-8 transition sm:grid-cols-[140px_1fr_auto] sm:items-start sm:gap-8">
                <time datetime={post.data.pubDate.toISOString()} class="text-meta">
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
                <div>
                  <h2 class="subsection-title transition group-hover:text-brand-300">
                    <a href={`/blog/${post.id}`}>{post.data.title}</a>
                  </h2>
                  <p class="body-text mt-2">{post.data.description}</p>
                  {
                    post.data.tags.length > 0 && (
                      <ul class="mt-3 flex flex-wrap gap-2">
                        {post.data.tags.map((tag) => (
                          <li class="rounded-full border border-white/10 px-2.5 py-0.5 text-xs text-brand-300">
                            {tag}
                          </li>
                        ))}
                      </ul>
                    )
                  }
                </div>
                <a href={`/blog/${post.id}`} class="text-link group-hover:translate-x-1">
                  Read →
                </a>
              </article>
            ))}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
