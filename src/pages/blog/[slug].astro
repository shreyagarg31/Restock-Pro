---
import { getCollection, render } from 'astro:content';
import BlogLayout from '@/layouts/BlogLayout.astro';
import { canonicalUrl } from '@/lib/seo';
import { getRelatedPosts } from '@/lib/blog';
import { SITE_NAME, SITE_URL } from '@/lib/constants';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, tags } = post.data;
const modified = updatedDate ?? pubDate;
const postUrl = canonicalUrl(`/blog/${post.id}`);
const related = getRelatedPosts(post, allPosts);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: title,
    description,
    datePublished: pubDate.toISOString(),
    dateModified: modified.toISOString(),
    author: { '@type': 'Organization', name: SITE_NAME },
    publisher: {
      '@type': 'Organization',
      name: SITE_NAME,
      url: SITE_URL,
    },
    mainEntityOfPage: postUrl,
    keywords: tags.join(', '),
    articleSection: tags[0] ?? 'Shopify',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: canonicalUrl('/blog') },
      { '@type': 'ListItem', position: 3, name: title, item: postUrl },
    ],
  },
];
---

<BlogLayout
  title={title}
  description={description}
  path={`/blog/${post.id}`}
  pubDate={pubDate}
  updatedDate={updatedDate}
  tags={tags}
  jsonLd={jsonLd}
  relatedPosts={related}
>
  <Content />
</BlogLayout>
