---
import BaseLayout from '@/layouts/BaseLayout.astro';
import InstallCTA from '@/components/InstallCTA.astro';
import { ShimmerButton } from '@/components/react/ShimmerButton';
import { buildMeta } from '@/lib/seo';
import { APP_INSTALL_URL } from '@/lib/constants';

const meta = buildMeta({
  title: 'Pricing',
  description:
    'Restock Pro is free at launch. Full access to back-in-stock alerts, demand insights, and exports for Shopify merchants.',
  path: '/pricing',
});
---

<BaseLayout {...meta}>
  <section class="border-b hairline px-4 py-20 sm:px-6">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="page-title">Simple pricing</h1>
      <p class="section-lead mt-4">
        Free at launch with everything included. Paid plans may come later — early merchants will be
        looked after.
      </p>
    </div>
  </section>

  <section class="px-4 py-16 sm:px-6">
    <div class="mx-auto grid max-w-4xl gap-8 md:grid-cols-2">
      <div class="relative rounded-2xl border-2 border-brand-500/60 bg-elevated p-8 glow-brand">
        <span class="absolute -top-3 left-6 rounded-full bg-brand-gradient px-3 py-1 text-xs font-medium text-white">
          CURRENT
        </span>
        <h2 class="subsection-title">Free at launch</h2>
        <p class="price-display mt-2">
          $0<span class="text-lg font-normal text-text-muted">/mo</span>
        </p>
        <p class="body-text mt-4">
          Everything included while we launch and learn from early merchants. Pricing may change
          later.
        </p>
        <ul class="card-body mt-6 space-y-3">
          <li>✓ Notify Me widget</li>
          <li>✓ Unlimited restock emails</li>
          <li>✓ Subscriber dashboard & CSV export</li>
          <li>✓ Dashboard metrics & demand insights</li>
          <li>✓ Customize emails and widget</li>
          <li>✓ Past events (notification history)</li>
          <li>✓ In-app support</li>
        </ul>
        <div class="mt-8">
          <ShimmerButton client:visible href={APP_INSTALL_URL} class="w-full !py-3">
            Install free on Shopify
          </ShimmerButton>
        </div>
      </div>

      <div class="glass-card p-8">
        <h2 class="subsection-title">Pro</h2>
        <p class="price-display mt-2 text-text-muted/50">Coming soon</p>
        <p class="body-text mt-4">
          Advanced capabilities for growing stores. On the roadmap — not available yet.
        </p>
        <ul class="card-body mt-6 space-y-3 text-text-muted/70">
          <li>Pre-order functionality</li>
          <li>SMS & multichannel alerts</li>
          <li>Advanced reporting</li>
          <li>Priority support</li>
          <li>Higher-volume plans</li>
        </ul>
      </div>
    </div>
  </section>

  <InstallCTA
    title="Get started free"
    description="Install Restock Pro and start capturing back-in-stock demand today."
  />
</BaseLayout>
