---
import BaseLayout from '@/layouts/BaseLayout.astro';
import InstallCTA from '@/components/InstallCTA.astro';
import { ScrollReveal } from '@/components/react/ScrollReveal';
import { buildMeta } from '@/lib/seo';

const meta = buildMeta({
  title: 'Features',
  description:
    'Notify Me widget, automatic restock emails, subscriber dashboard, demand insights, past events, and CSV exports for Shopify merchants.',
  path: '/features',
});

const features = [
  {
    title: 'Notify Me widget',
    description:
      'A theme app extension on out-of-stock product pages. Customers expand the form, enter their email, and join the waitlist — no account required. Tracks the selected variant (size, color, and more).',
    bullets: [
      'Variant-aware waitlists',
      'Customize colors, fonts, and button copy',
      'Enable in the theme editor — no code',
      'Works on mobile and desktop',
    ],
    images: [
      {
        src: '/screenshots/feature-widget.png',
        alt: 'Notify Me form on an out-of-stock headphones product page',
      },
    ],
  },
  {
    title: 'Automatic restock emails',
    description:
      'When inventory returns in Shopify, Restock Pro sends notification emails automatically. No spreadsheets, no manual sends.',
    bullets: [
      'Sends when stock is back',
      'Unsubscribe link in every email',
      'Customize subject, message, and CTA',
    ],
    images: [
      {
        src: '/screenshots/feature-email.png',
        alt: 'Back-in-stock email for AeroPulse headphones with Shop Now button',
      },
    ],
  },
  {
    title: 'Subscriber management',
    description:
      'View every customer waiting for a restock. Filter by product, export your list, and see who is still waiting.',
    bullets: [
      'Centralized subscriber list',
      'Export to CSV',
      'Filter by product and status',
    ],
    images: [
      {
        src: '/screenshots/feature-subscribers.png',
        alt: 'Subscribers page with search, status filter, and product waitlists',
      },
    ],
  },
  {
    title: 'Dashboard',
    description:
      'See how your waitlist is growing, demand by day, and capturable value at a glance.',
    bullets: [
      'Subscriber growth trends',
      'Demand heatmap by day',
      'Notifications and successful restocks',
      'Capturable value metric',
    ],
    images: [
      {
        src: '/screenshots/feature-dashboard.png',
        alt: 'Dashboard overview with metrics, growth chart, and demand heatmap',
      },
    ],
  },
  {
    title: 'Demand insights',
    description:
      'Rank products by waitlist interest and potential value so you can restock what customers actually want.',
    bullets: [
      'Total capturable value',
      'Highest demand product highlight',
      'Full product leaderboard with demand meter',
    ],
    images: [
      {
        src: '/screenshots/feature-demand-summary.png',
        alt: 'Demand Intelligence with total capturable value and highest demand product',
      },
      {
        src: '/screenshots/feature-demand-leaderboard.png',
        alt: 'Demand leaderboard ranking products by subscribers and potential revenue',
      },
    ],
  },
  {
    title: 'Past events',
    description:
      'Review outbound email delivery in one place. See what was sent, when, and whether it was delivered, bounced, or failed.',
    bullets: [
      'Email notification history',
      'Delivery status for each send',
      'Provider and timestamp for every event',
    ],
    images: [
      {
        src: '/screenshots/feature-events.png',
        alt: 'Event History table with delivered, failed, and bounced email statuses',
      },
    ],
  },
];
---

<BaseLayout {...meta}>
  <section class="border-b hairline px-4 py-20 sm:px-6">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="page-title">Features</h1>
      <p class="section-lead mt-4">
        Everything you need to capture demand during stockouts and follow up when inventory returns.
      </p>
    </div>
  </section>

  <section class="px-4 py-16 sm:px-6">
    <div class="mx-auto max-w-4xl space-y-20">
      {
        features.map((feature, i) => (
          <ScrollReveal client:visible delay={i * 0.05}>
            <article
              class:list={[
                'grid gap-8 md:grid-cols-2 md:items-center',
                i % 2 === 1 && 'md:[&>*:first-child]:order-2',
              ]}
            >
              <div>
                <h2 class="subsection-title">{feature.title}</h2>
                <p class="body-text mt-3">{feature.description}</p>
                <ul class="mt-4 space-y-2">
                  {feature.bullets.map((b) => (
                    <li class="card-body flex items-start gap-2">
                      <span class="mt-0.5 text-brand-400">✓</span>
                      {b}
                    </li>
                  ))}
                </ul>
              </div>
              <div class="glass-card glow-brand space-y-3 overflow-hidden p-4">
                {feature.images.map((img) => (
                  <div class="overflow-hidden rounded-xl border border-white/10 bg-[#f5f5f5]">
                    <img
                      src={img.src}
                      alt={img.alt}
                      class="h-auto w-full object-contain object-top"
                      loading="lazy"
                    />
                  </div>
                ))}
              </div>
            </article>
          </ScrollReveal>
        ))
      }
    </div>
  </section>

  <InstallCTA />
</BaseLayout>
