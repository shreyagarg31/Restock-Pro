---
import { SITE_NAME, NAV_LINKS, APP_INSTALL_URL } from '@/lib/constants';
import { ShimmerButton } from '@/components/react/ShimmerButton';
---

<header class="sticky top-0 z-50 border-b hairline bg-base/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <a href="/" class="flex items-center gap-3">
      <img src="/logo.png" alt={SITE_NAME} width="36" height="36" class="rounded-lg" />
      <span class="brand-wordmark">{SITE_NAME}</span>
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Main">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class="text-sm text-text-muted transition hover:text-white"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <ShimmerButton
      client:load
      href={APP_INSTALL_URL}
      class="!px-4 !py-2 text-xs"
    >
      Install app
    </ShimmerButton>
  </div>
</header>
