---
import { SITE_NAME, NAV_LINKS, SUPPORT_EMAIL } from '@/lib/constants';

const year = new Date().getFullYear();
---

<footer class="border-t hairline bg-base">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 px-4 py-10 sm:flex-row sm:px-6">
    <a href="/" class="flex items-center gap-2">
      <img src="/logo.png" alt="" width="28" height="28" class="rounded-md" />
      <span class="brand-wordmark">{SITE_NAME}</span>
    </a>

    <p class="text-sm text-text-muted">© {year} {SITE_NAME}. All rights reserved.</p>

    <nav class="flex flex-wrap items-center justify-center gap-6" aria-label="Footer">
      {
        [...NAV_LINKS, { href: '/privacy', label: 'Privacy' }, { href: '/terms', label: 'Terms' }].map(
          (link) => (
            <a href={link.href} class="text-sm text-text-muted transition hover:text-brand-300">
              {link.label}
            </a>
          ),
        )
      }
      <a href={`mailto:${SUPPORT_EMAIL}`} class="text-sm text-text-muted transition hover:text-brand-300">
        Contact
      </a>
    </nav>
  </div>
</footer>
