---
import { APP_INSTALL_URL } from '@/lib/constants';
import { ShimmerButton } from '@/components/react/ShimmerButton';

interface Props {
  title?: string;
  description?: string;
  class?: string;
}

const {
  title = 'Start capturing back-in-stock demand',
  description = 'Install Restock Pro on Shopify and enable the Notify Me widget in minutes.',
  class: className = '',
} = Astro.props;
---

<section class:list={['relative overflow-hidden px-4 py-20 sm:px-6', className]}>
  <div class="pointer-events-none absolute inset-0 bg-brand-gradient opacity-10" />
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute left-1/2 top-0 h-64 w-96 -translate-x-1/2 rounded-full bg-brand-violet/20 blur-3xl" />
  </div>

  <div class="relative mx-auto max-w-3xl text-center">
    <h2 class="section-title">{title}</h2>
    <p class="section-lead mt-4">{description}</p>
    <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <ShimmerButton client:visible href={APP_INSTALL_URL} class="!px-8 !py-3">
        Install on Shopify
      </ShimmerButton>
      <ShimmerButton client:visible href="/features" variant="outline" class="!px-8 !py-3">
        See features
      </ShimmerButton>
    </div>
  </div>
</section>
